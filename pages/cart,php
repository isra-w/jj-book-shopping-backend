                                </form>
                            </td>
                            <td data-label="Total"><strong><?php echo CURRENCY; ?> <?php echo number_format($item_total, 2); ?></strong></td>
                            <td>
                                <a href="cart.php?remove=<?php echo $item['id']; ?>" class="remove-btn" onclick="return confirm('Remove this item?')">
