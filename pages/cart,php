                <div class="summary-row"><span>Subtotal</span><span><?php echo CURRENCY; ?> <?php echo number_format($subtotal, 2); ?></span></div>
                <div class="summary-row"><span>Shipping</span><span><?php echo $shipping > 0 ? CURRENCY . ' ' . number_format($shipping, 2) : 'Free'; ?></span></div>
